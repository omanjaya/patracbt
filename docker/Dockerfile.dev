# Go Development Image dengan Air (hot reload)
FROM golang:1.26-alpine

# Install Air untuk hot reload
RUN go install github.com/air-verse/air@latest

WORKDIR /app

# Copy go.mod dan go.sum dulu (layer caching)
COPY go.mod go.sum ./
RUN go mod download

# Source code di-mount via volume, tidak perlu COPY
EXPOSE 8080

CMD ["air", "-c", ".air.toml"]
