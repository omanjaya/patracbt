APP_ENV=development
APP_PORT=8080
APP_SECRET=dev-secret-change-in-production-32chars

JWT_ACCESS_SECRET=dev-access-secret-32chars-minimum
JWT_REFRESH_SECRET=dev-refresh-secret-32chars-minimum
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=cbt_patra
DB_USERNAME=cbt_user
DB_PASSWORD=cbt_password
DB_MAX_OPEN=25
DB_MAX_IDLE=5

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=cbt-patra
MINIO_USE_SSL=false

AI_API_URL=
AI_API_KEY=
AI_API_HEADER=Authorization

ALLOWED_ORIGINS=http://localhost:5173

LOG_LEVEL=debug

HASHID_SALT=your-secret-salt-here
HASHID_MIN_LENGTH=8
