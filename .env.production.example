# =============================================================
# CBT Patra - Production Environment Variables
# Copy file ini ke .env dan isi semua value sebelum deploy
# =============================================================

# ─── App ──────────────────────────────────────────
APP_ENV=production
APP_PORT=8080
APP_SECRET=GANTI_DENGAN_RANDOM_STRING_MINIMAL_32_KARAKTER

# ─── JWT ──────────────────────────────────────────
# Generate dengan: openssl rand -hex 32
JWT_ACCESS_SECRET=GANTI_DENGAN_ACCESS_SECRET_MINIMAL_32_KARAKTER
JWT_REFRESH_SECRET=GANTI_DENGAN_REFRESH_SECRET_MINIMAL_32_KARAKTER
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ─── PostgreSQL ───────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=cbt_patra
DB_USERNAME=cbt_user
DB_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT
DB_MAX_OPEN=100
DB_MAX_IDLE=20

# ─── Redis ────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=GANTI_DENGAN_REDIS_PASSWORD
REDIS_DB=0

# ─── MinIO (Object Storage) ──────────────────────
# Kosongkan jika tidak pakai MinIO di production
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=cbt-patra
MINIO_USE_SSL=true

# ─── AI Integration ──────────────────────────────
AI_API_URL=
AI_API_KEY=
AI_API_HEADER=Authorization

# ─── CORS ─────────────────────────────────────────
# Ganti dengan domain production (tanpa trailing slash)
ALLOWED_ORIGINS=https://cbt.yourdomain.com

# ─── Logging ──────────────────────────────────────
LOG_LEVEL=info
